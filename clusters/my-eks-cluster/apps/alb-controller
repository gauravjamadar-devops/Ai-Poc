apiVersion: helm.toolkit.fluxcd.io/v2beta1
kind: HelmRelease
metadata:
  name: aws-load-balancer-controller
  namespace: kube-system
spec:
  interval: 5m
  chart:
    spec:
      chart: aws-load-balancer-controller
      version: 1.6.0
      sourceRef:
        kind: HelmRepository
        name: eks-charts
        namespace: flux-system
  install:
    createNamespace: false
  values:
    clusterName: my-eks-cluster
    region: <your-region>
